# II Private Messenger — backend environment
NODE_ENV=production
PORT=3000

# Database
DATABASE_URL=postgres://iipm:iipm@postgres:5432/iipm

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Inter-node (relay <-> backend) shared secret
INTER_NODE_SECRET=change-me-inter-node-shared-secret

# TURN REST API shared secret (coturn use-auth-secret)
TURN_SHARED_SECRET=change-me-turn-shared-secret
TURN_TTL_SECONDS=86400

# Firebase Admin (stringified service-account JSON)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Region relay/turn URLs
RELAY_URL_RU=wss://relay-ru.iiprivatemessenger.app
RELAY_URL_GE=wss://relay-ge.iiprivatemessenger.app
RELAY_URL_FI=wss://relay-fi.iiprivatemessenger.app

TURN_URL_RU=turns:turn-ru.iiprivatemessenger.app:5349
TURN_URL_GE=turns:turn-ge.iiprivatemessenger.app:5349
TURN_URL_FI=turns:turn-fi.iiprivatemessenger.app:5349

# Anti-censorship transport (VLESS + XTLS-Vision + REALITY) per la region RU.
# Distribuito ai client in Russia: l'app avvia un tunnel per-app verso questo proxy.
# pbk/sid/sni sono pubblici; PROXY_UUID_RU è la credenziale di accesso (tienila riservata).
# Se PROXY_SERVER_RU è vuoto, nessun proxy_config viene distribuito (campo null).
PROXY_SERVER_RU=
PROXY_PORT_RU=443
PROXY_UUID_RU=
PROXY_PBK_RU=
PROXY_SID_RU=
PROXY_SNI_RU=www.apple.com
PROXY_FLOW_RU=xtls-rprx-vision
PROXY_FP_RU=chrome

# CORS
CORS_ORIGINS=*

# Rate limits
RATE_LIMIT_AUTH_PER_MIN=10
RATE_LIMIT_GENERAL_PER_MIN=100
