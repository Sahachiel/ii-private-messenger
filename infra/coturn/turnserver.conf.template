listening-port=3478
tls-listening-port=5349
listening-ip=0.0.0.0
relay-ip=0.0.0.0
external-ip=__SERVER_IP__
realm=__DOMAIN__
use-auth-secret
static-auth-secret=__TURN_SECRET__
total-quota=100
bps-capacity=0
stale-nonce=600
no-multicast-peers
no-loopback-peers
no-tlsv1
no-tlsv1_1
cert=/etc/letsencrypt/live/__DOMAIN__/fullchain.pem
pkey=/etc/letsencrypt/live/__DOMAIN__/privkey.pem
min-port=49152
max-port=65535
denied-peer-ip=10.0.0.0-10.255.255.255
denied-peer-ip=172.16.0.0-172.31.255.255
denied-peer-ip=192.168.0.0-192.168.255.255
log-file=/var/log/turnserver/turn.log
pidfile=/var/run/turnserver.pid
verbose
