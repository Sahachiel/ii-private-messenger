{
  "name": "ii-private-messenger-desktop",
  "version": "0.3.0",
  "description": "II Private Messenger — desktop client (Windows/macOS/Linux)",
  "main": "dist/main.js",
  "private": true,
  "scripts": {
    "dev": "tsc && electron dist/main.js",
    "build": "tsc && electron-builder --publish never",
    "build:win": "tsc && electron-builder --win --publish never",
    "build:mac": "tsc && electron-builder --mac --publish never",
    "build:linux": "tsc && electron-builder --linux --publish never"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "electron-store": "^8.1.0",
    "keytar": "^7.9.0",
    "qrcode-generator": "^1.4.4",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "5.3.3"
  },
  "build": {
    "appId": "com.oleventechnologies.iiprivatemessenger.desktop",
    "productName": "II Private Messenger",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "renderer/**/*",
      "assets/**/*",
      "build/**/*"
    ],
    "icon": "build/icon.ico",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "menuCategory": false,
      "shortcutName": "II Private Messenger",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.social-networking"
    },
    "linux": {
      "target": "AppImage",
      "category": "Network"
    }
  }
}
